{
  "name": "dev-harness-template",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic-development harness template — guardrails wired and green on clone.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gate": "npm run format:check && npm run lint && npm run typecheck && npm run build && npm test && npm run test:smoke:dist",
    "dev": "node tools/dev.mjs",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w frontend && npm run build -w backend",
    "start": "npm start -w backend",
    "test": "npm test -w backend && npm test -w frontend",
    "test:backend": "npm test -w backend",
    "test:frontend": "npm test -w frontend",
    "test:integration": "npm test -w backend -- ../tests/integration",
    "test:smoke:dist": "node tools/smoke.mjs",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "tsc -p tsconfig.typecheck.json",
    "typecheck:frontend": "tsc -p frontend/tsconfig.typecheck.json",
    "test:ui": "CC_INTEGRATION=1 playwright test e2e/ui",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}

# Copy to .env (gitignored) and override as needed. Every variable here is
# resolved in backend/src/config.ts — keep THIS file, that file, and the CLAUDE.md
# "Environment variables" table in sync (the docs-audit skill checks for drift).

# Backend HTTP port (integer 1..65535). Boot fails loud on an invalid value.
PORT=8137

# Bind address. Loopback by default.
HOST=127.0.0.1

# SQLite location. ':memory:' (default) keeps no file artifact — and under
# `npm run dev` (tsx watch) EVERY FILE SAVE restarts the process and wipes it.
# Point at a file for data that survives saves (gitignored via *.db):
# DB_PATH=./dev.db
DB_PATH=:memory:

# Minimum level backend/src/lib/logger.ts emits: debug|info|warn|error.
# Boot fails loud on any other value.
LOG_LEVEL=info
